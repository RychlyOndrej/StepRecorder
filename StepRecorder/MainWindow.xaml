<Window x:Class="StepRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StepRecorder"
        Height="720" Width="960"
        MinHeight="620" MinWidth="840"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Border Grid.Row="0" Background="#0078D4">
            <Grid Margin="20,13">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="StepRecorder" Foreground="White"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Nahrávač postupů pro desktopové aplikace"
                               Foreground="#B3D9FF" FontSize="11"/>
                </StackPanel>

                <!-- Recording badge -->
                <Border x:Name="RecordingBadge" Grid.Column="1"
                        Background="#005A9E" CornerRadius="6"
                        Padding="14,8" Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="RecDot" Width="10" Height="10"
                                 Fill="#FF4444" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                From="1" To="0.2" Duration="0:0:0.85" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="RecBadgeText"
                                   Text="NAHRÁVÁM  •  0 kroků"
                                   Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ TAB CONTROL ══════════ -->
        <TabControl Grid.Row="1" x:Name="MainTabs"
                    TabStripPlacement="Left"
                    Background="White"
                    BorderThickness="0"
                    Padding="0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="12.5"/>
                    <Setter Property="Foreground" Value="#333"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        BorderThickness="0,0,3,0"
                                        BorderBrush="Transparent"
                                        Padding="16,11">
                                    <ContentPresenter ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#EFF6FC"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ─────────────────────────────────────────────────
                 TAB 1  ·  RELACE
            ───────────────────────────────────────────────────── -->
            <TabItem Header="📁  Relace">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,22,28,22" MaxWidth="680">

                        <TextBlock Text="Nastavení relace"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#111" Margin="0,0,0,16"/>

                        <!-- Basic info -->
                        <GroupBox Header="Základní informace">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Název relace:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                         x:Name="SessionNameBox"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Výstupní složka:"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         x:Name="OutputFolderBox" IsReadOnly="True"/>
                                <Button Grid.Row="2" Grid.Column="2"
                                        Content="📂 Procházet…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6" Margin="6,0,0,0"
                                        Click="BrowseFolder_Click"/>

                                <Label Grid.Row="4" Grid.Column="0" Content="Autor:"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                         x:Name="AuthorBox"/>

                                <Label Grid.Row="6" Grid.Column="0" x:Name="LanguageLabel" Content="Jazyk UI:"/>
                                <ComboBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                                          x:Name="LanguageCombo"
                                          SelectionChanged="LanguageCombo_SelectionChanged">
                                    <ComboBoxItem Tag="cs">Cestina</ComboBoxItem>
                                    <ComboBoxItem Tag="en">English</ComboBoxItem>
                                </ComboBox>

                                <Label Grid.Row="8" Grid.Column="0" x:Name="ThemeLabel" Content="Motiv:"/>
                                <ComboBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                                          x:Name="ThemeCombo"
                                          SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Tag="light">Svetly</ComboBoxItem>
                                    <ComboBoxItem Tag="dark">Tmavy</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                        <!-- Export formats -->
                        <GroupBox Header="Výstupní formáty">
                            <StackPanel>
                                <CheckBox x:Name="ExportPdfCheck"
                                          Content="PDF  – číslované kroky se screenshoty a popisky"/>
                                <CheckBox x:Name="ExportMhtCheck"
                                          Content="MHT  – webový archiv, otevřít v Edge / IE"/>
                                <CheckBox x:Name="ExportWordCheck"
                                          Content="Word  – .docx dokument se screenshoty"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Layout -->
                        <GroupBox Header="Rozložení dokumentu">
                            <StackPanel>
                                <RadioButton x:Name="LayoutNumbered"
                                             Content="Číslované kroky  (Krok 1, Krok 2 …)"/>
                                <RadioButton x:Name="LayoutDetailed"
                                             Content="Detailní kroky  (screenshot + popis + metadata)"/>
                                <RadioButton x:Name="LayoutScreenshotsOnly"
                                             Content="Pouze screenshoty  (bez textového popisu)"/>
                                <Separator Margin="0,8"/>
                                <CheckBox x:Name="IncludeTimestampsCheck"
                                          Content="Zahrnout časové razítko u každého kroku"/>
                                <CheckBox x:Name="IncludeWindowTitlesCheck"
                                          Content="Zahrnout název okna a aplikace"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Image quality -->
                        <GroupBox Header="Kvalita snímků">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Formát uložení:"/>
                                <ComboBox Grid.Column="1" x:Name="ImageQualityCombo">
                                    <ComboBoxItem Content="PNG  (bezztrátový, větší soubor)" Tag="PNG"/>
                                    <ComboBoxItem Content="JPEG 85 %  (výchozí, vhodná kvalita)" Tag="JPEG85"/>
                                    <ComboBoxItem Content="JPEG 70 %  (nejmenší soubory)" Tag="JPEG70"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─────────────────────────────────────────────────
                 TAB 2  ·  NAHRÁVÁNÍ
            ───────────────────────────────────────────────────── -->
            <TabItem Header="⏺  Nahrávání">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,22,28,12" MaxWidth="680">

                            <TextBlock Text="Ovládání nahrávání"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#111" Margin="0,0,0,16"/>

                            <!-- Target window -->
                            <GroupBox Header="Cílová aplikace">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Zvolené okno:"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              x:Name="TargetWindowCombo"
                                              DisplayMemberPath="."
                                              DropDownOpened="TargetWindowCombo_DropDownOpened"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Content="🔄" ToolTip="Obnovit seznam"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,6" Margin="6,0,0,0"
                                            Click="RefreshWindows_Click"/>

                                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                              x:Name="CaptureWindowOnlyCheck"
                                              Content="Zachycovat pouze oblast vybraného okna (bez taskbaru)"/>
                                </Grid>
                            </GroupBox>

                            <!-- Capture triggers -->
                            <GroupBox Header="Spouštěče zachycení">
                                <StackPanel>
                                    <CheckBox x:Name="CaptureOnClickCheck"
                                              Content="Screenshot při každém kliknutí levým tlačítkem myši"/>
                                    <Separator Margin="0,6"/>
                                    <CheckBox x:Name="CaptureOnHotkeyCheck"
                                              Content="Screenshot na klávesové zkratky:"/>

                                    <Grid Margin="20,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="6"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0"
                                               Content="Celé okno / celá obrazovka:"/>
                                        <Border Grid.Row="0" Grid.Column="1"
                                                Background="White" BorderBrush="#D0D0D0"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="8,5" VerticalAlignment="Center">
                                            <TextBlock x:Name="HotkeyFullText"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </Border>
                                        <Button Grid.Row="0" Grid.Column="2"
                                                Content="Změnit"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="8,5" Margin="6,0,0,0"
                                                Click="ChangeHotkeyFull_Click"/>

                                        <Label Grid.Row="2" Grid.Column="0"
                                               Content="Výřez kolem myši:"/>
                                        <Border Grid.Row="2" Grid.Column="1"
                                                Background="White" BorderBrush="#D0D0D0"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="8,5" VerticalAlignment="Center">
                                            <TextBlock x:Name="HotkeyCropText"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </Border>
                                        <Button Grid.Row="2" Grid.Column="2"
                                                Content="Změnit"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="8,5" Margin="6,0,0,0"
                                                Click="ChangeHotkeyCrop_Click"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <!-- Crop size -->
                            <GroupBox Header="Velikost výřezu (crop) kolem myši">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Rozměry (px):"/>
                                    <TextBox Grid.Column="1" x:Name="CropWidthBox"
                                             Text="640" TextAlignment="Center"/>
                                    <Label Grid.Column="2" Content="×"
                                           HorizontalAlignment="Center"/>
                                    <TextBox Grid.Column="3" x:Name="CropHeightBox"
                                             Text="400" TextAlignment="Center"/>
                                </Grid>
                            </GroupBox>

                            <!-- Annotations -->
                            <GroupBox Header="Anotace snímků">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <CheckBox x:Name="HighlightCursorCheck"
                                                  Content="Zvýraznit místo kliknutí"/>
                                        <CheckBox x:Name="ShowStepNumberBadgeCheck"
                                                  Content="Zobrazit číslo kroku na screenshotu"/>
                                        <CheckBox x:Name="RecordKeystrokesCheck"
                                                  Content="Zaznamenat stisknuté klávesy"/>
                                        <CheckBox x:Name="RecordWindowNameCheck"
                                                  Content="Zaznamenat název okna"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Barva kruhu:"/>
                                            <Border Grid.Column="1" x:Name="ColorPreviewBorder"
                                                    Width="36" Height="22" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Background="Red" Cursor="Hand"
                                                    MouseLeftButtonDown="ColorPreview_Click"/>
                                        </Grid>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Poloměr kruhu:"/>
                                            <TextBox Grid.Column="1"
                                                     x:Name="CursorRadiusBox"
                                                     Text="25" TextAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Start / Stop buttons -->
                    <Border Grid.Row="1" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                            Padding="28,14">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartBtn"
                                    Content="▶  Spustit nahrávání"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="180" Height="38"
                                    Click="StartRecording_Click"/>
                            <Button x:Name="StopBtn"
                                    Content="⏹  Zastavit a exportovat"
                                    Style="{StaticResource DangerButton}"
                                    Width="200" Height="38"
                                    Margin="10,0,0,0"
                                    IsEnabled="False"
                                    Click="StopRecording_Click"/>
                            <Button x:Name="MinimizeToTrayBtn"
                                    Content="⬇  Minimalizovat do tray"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="38" Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    Click="MinimizeToTray_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────────────
                 TAB 3  ·  KROKY
            ───────────────────────────────────────────────────── -->
            <TabItem Header="📋  Kroky">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Step list -->
                    <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F7F7F7"
                                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                                    Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Zaznamenané kroky"
                                               FontWeight="SemiBold" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#0078D4" CornerRadius="10"
                                            Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock x:Name="StepCountBadge" Text="0"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <ListBox Grid.Row="1" x:Name="StepListBox"
                                     BorderThickness="0"
                                     Background="White"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="StepListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,4,4,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="28" Height="28"
                                                    Background="#0078D4" CornerRadius="14"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StepNumber}"
                                                           Foreground="White"
                                                           FontWeight="Bold" FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="#111"/>
                                                <TextBlock FontSize="10" Foreground="#888">
                                                    <Run Text="{Binding TimeDisplay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding SourceIcon}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EFF6FC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <Border Grid.Row="2" Background="#F7F7F7"
                                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                                    Padding="10,8">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🗑 Smazat krok"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,5" FontSize="11"
                                            Click="DeleteStep_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Step detail -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="16">
                            <StackPanel x:Name="StepDetailPanel">

                                <!-- Empty state -->
                                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                                            Margin="0,80,0,0">
                                    <TextBlock Text="📋" FontSize="48"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Vyberte krok ze seznamu"
                                               FontSize="14" Foreground="#888"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="nebo spusťte nahrávání na záložce Nahrávání"
                                               FontSize="11" Foreground="#AAA"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Step detail content -->
                                <StackPanel x:Name="StepDetailContent" Visibility="Collapsed">

                                    <!-- Screenshot -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                            CornerRadius="4" Background="White">
                                        <Image x:Name="StepScreenshot"
                                               MaxHeight="360"
                                               Stretch="Uniform"
                                               Margin="4"/>
                                    </Border>

                                    <!-- Metadata -->
                                    <Border Background="White" BorderBrush="#E0E0E0"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="0,10,0,0" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Metadata kroku"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Margin="0,0,0,10"/>

                                            <Grid x:Name="StepMetaGrid">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="4"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="4"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="4"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Grid.Column="0"
                                                       Content="Čas:" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           x:Name="MetaTime"
                                                           VerticalAlignment="Center" FontSize="12"/>

                                                <Label Grid.Row="2" Grid.Column="0"
                                                       Content="Aplikace:" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1"
                                                           x:Name="MetaWindow"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           TextWrapping="Wrap"/>

                                                <Label Grid.Row="4" Grid.Column="0"
                                                       Content="Klávesy:" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Row="4" Grid.Column="1"
                                                           x:Name="MetaKeys"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           FontFamily="Consolas"/>

                                                <Label Grid.Row="6" Grid.Column="0"
                                                       Content="Zdroj:" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Row="6" Grid.Column="1"
                                                           x:Name="MetaSource"
                                                           VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Description -->
                                    <Border Background="White" BorderBrush="#E0E0E0"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="0,10,0,0" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Popis kroku"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Margin="0,0,0,6"/>
                                            <TextBox x:Name="StepDescriptionBox"
                                                     Height="64"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     TextChanged="StepDescription_Changed"
                                                     FontSize="12"
                                                     Padding="8,6"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Open image button -->
                        <Border Grid.Row="1" Background="#F7F7F7"
                                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                                Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="OpenImageBtn"
                                        Content="🖼 Otevřít obrázek"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6" FontSize="11"
                                        IsEnabled="False"
                                        Click="OpenImage_Click"/>
                                <Button x:Name="OpenFolderBtn"
                                        Content="📂 Otevřít složku"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6" FontSize="11"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="OpenFolder_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────────────
                 TAB 4  ·  EXPORT
            ───────────────────────────────────────────────────── -->
            <TabItem Header="📤  Export">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,22,28,14" MaxWidth="680">

                            <TextBlock Text="Exportovat nahrávku"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#111" Margin="0,0,0,16"/>

                            <!-- Session summary -->
                            <GroupBox Header="Aktuální relace">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Název:"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               x:Name="ExportSessionName"
                                               VerticalAlignment="Center" FontSize="12"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="Počet kroků:"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               x:Name="ExportStepCount"
                                               VerticalAlignment="Center" FontSize="12"/>

                                    <Label Grid.Row="4" Grid.Column="0" Content="Výstupní složka:"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               x:Name="ExportOutputFolder"
                                               VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </GroupBox>

                            <!-- Progress -->
                            <Border x:Name="ExportProgressPanel"
                                    Background="White" BorderBrush="#E0E0E0"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="16,14" Margin="0,0,0,8"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="ExportProgressLabel"
                                               Text="Exportuji…" FontSize="12"
                                               Margin="0,0,0,8"/>
                                    <ProgressBar x:Name="ExportProgressBar"
                                                 Height="8" IsIndeterminate="True"
                                                 Foreground="#0078D4"/>
                                </StackPanel>
                            </Border>

                            <!-- Results -->
                            <Border x:Name="ExportResultPanel"
                                    Background="#F0FFF4" BorderBrush="#4CAF50"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,12" Margin="0,0,0,8"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="✅  Export dokončen!" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#2E7D32"
                                               Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="ExportedFilesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,2">
                                                    <Hyperlink Click="ExportedFile_Click"
                                                               Tag="{Binding Path=., Mode=OneWay}">
                                                        <Run Text="{Binding Path=., Mode=OneWay}"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Export button -->
                    <Border Grid.Row="1" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                            Padding="28,14">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ExportBtn"
                                    Content="📤  Exportovat nyní"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="180" Height="38"
                                    IsEnabled="False"
                                    Click="Export_Click"/>
                            <Button Content="📂  Otevřít výstupní složku"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="38" Margin="10,0,0,0"
                                    Click="OpenOutputFolder_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══════════ STATUS BAR ══════════ -->
        <Border Grid.Row="2" Background="#EFEFEF"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="14,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="Připraven k nahrávání."
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="#555"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="HotkeyHintText"
                               FontSize="10" Foreground="#888"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
