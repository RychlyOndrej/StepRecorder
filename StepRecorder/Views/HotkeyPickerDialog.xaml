<Window x:Class="StepRecorder.HotkeyPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nastavit klávesovou zkratku"
        Width="400" Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3">

    <StackPanel Margin="28,24">

        <TextBlock x:Name="DialogHeaderText"
                   Text="Stiskněte novou klávesovou zkratku"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="DialogHintText"
                   Text="Použijte kombinaci: Ctrl / Shift / Alt + klávesa"
                   FontSize="11" Foreground="#666" Margin="0,0,0,18"/>

        <!-- Preview box — focusable, catches KeyDown -->
        <Border x:Name="HotkeyBorder"
                Background="White" BorderBrush="#0078D4"
                BorderThickness="2" CornerRadius="4"
                Padding="14,10" Margin="0,0,0,6">
            <TextBlock x:Name="HotkeyPreviewText"
                       FontFamily="Consolas" FontSize="16"
                       HorizontalAlignment="Center"
                       Text="Klikněte sem a stiskněte zkratku…"
                       Foreground="#888"/>
        </Border>

        <TextBlock x:Name="HotkeyErrorText"
                   Foreground="#C42B1C" FontSize="11"
                   Margin="0,0,0,14" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelBtn" Content="Zrušit" Width="80" Height="32" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button x:Name="OkBtn" Content="Uložit" Width="80" Height="32"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True" IsEnabled="False"
                    Click="Ok_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
